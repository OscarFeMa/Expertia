# Expertia — Configuration overrides
# Copy to .env and uncomment to override defaults

# Wikidata paths (defaults: Windows E:\ paths)
# EXPERTIA_WIKIDATA_PATH=./data/latest-all.json.gz
# EXPERTIA_OUTPUT_DIR=./data/output
# EXPERTIA_EXTRACTION_TIMEOUT_HOURS=4.0

# Ollama
# EXPERTIA_OLLAMA_HOST=localhost
# EXPERTIA_OLLAMA_PORT=11434

# Database
# EXPERTIA_DATABASE_PATH=./storage/incubator.db

# Pipeline limits
# EXPERTIA_SUBSPECIALIST_THRESHOLD=100
# EXPERTIA_MAX_SUBSPECIALISTS=20
# EXPERTIA_SUBSPECIALIST_CYCLE_INTERVAL=10
# EXPERTIA_MAX_CHILDREN_PER_PARENT=3
